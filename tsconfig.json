{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": ["node_modules"],
  "include": [".plasmo/index.d.ts", "src/**/*.ts", "src/**/*.tsx"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~lib/*": ["src/lib/*"],
      "~components/*": ["src/components/*"],
      "~hooks/*": ["src/hooks/*"]
    }
  }
}
